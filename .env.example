# ============================================================
# rr7x-portal (Mandor) — Template de variáveis de ambiente
# ============================================================
# Este arquivo NÃO contém segredos — só os NOMES e descrições.
# Os VALORES reais ficam em .env.local (gitignored) e no painel da Vercel.
# Guarde os valores num cofre de senhas (1Password/Bitwarden). Ver docs/seguranca/SEGREDOS.md.
# Para recuperar o ambiente: copie este arquivo para .env.local e preencha.

# ── Públicas (não são segredo; podem ir ao client) ──────────
NEXT_PUBLIC_SUPABASE_URL=            # URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # chave anônima (pública) do Supabase
NEXT_PUBLIC_APP_URL=                 # ex.: https://www.mandor.com.br
NEXT_PUBLIC_SITE_URL=                # ex.: https://www.mandor.com.br
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=  # chave pública do Stripe
RESEND_FROM_EMAIL=                   # remetente dos e-mails (ex.: mandor@rr7x.com.br)

# ── Config (não secreta) ────────────────────────────────────
ANTHROPIC_MODEL_OVERRIDE=            # opcional: força um modelo Claude
INGESTION_WATCHDOG_GRACE_MIN=        # opcional: minutos do watchdog (default 60)
USD_BRL_RATE=                        # opcional: taxa de câmbio fallback
STRIPE_PRICE_AVULSO=                 # ID do preço Stripe (pontual)
STRIPE_PRICE_RECORRENTE=             # ID do preço Stripe (recorrente)

# ── SEGREDOS (NUNCA commitar/compartilhar — vault) ──────────
SUPABASE_SERVICE_ROLE_KEY=           # acesso TOTAL ao banco (crítico)
ENCRYPTION_KEY=                      # CRÍTICO: cifra PII do intake. Se perder, PII fica irrecuperável.
INTERNAL_PIPELINE_TOKEN=             # auth interna server-to-server do pipeline
SHARE_TOKEN_SECRET=                  # assina os links de compartilhamento de relatório
NEXTAUTH_SECRET=                     # segredo de sessão (se usado)
ANTHROPIC_API_KEY=                   # Claude (LLM)
VOYAGE_API_KEY=                      # embeddings (voyage-3-large)
MISTRAL_API_KEY=                     # OCR de documentos
INNGEST_EVENT_KEY=                   # envio de eventos Inngest
INNGEST_SIGNING_KEY=                 # assinatura/serve Inngest
RESEND_API_KEY=                      # envio de e-mails (Resend)
STRIPE_SECRET_KEY=                   # pagamentos (Stripe)
STRIPE_WEBHOOK_SECRET=               # validação do webhook Stripe
